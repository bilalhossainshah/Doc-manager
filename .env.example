# Database Configuration
DATABASE_URL=sqlite:///./sql_app.db

# Gemini API Key (Required for RAG embeddings and LLM responses)
GEMINI_API_KEY=your_gemini_api_key_here

# Directory Settings
CHROMA_DB_DIR=chroma_db
UPLOAD_DIR=uploads

# AWS S3 Configuration (Optional: fallback to local uploads directory if not set)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
REGION=us-east-1
BUCKET_NAME=
